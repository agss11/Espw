<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF050A08"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Pratinjau kamera -->
    <TextureView
        android:id="@+id/texture_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Lapisan deteksi ESP (overlay) -->
    <com.detector.esp.ui.OverlayView
        android:id="@+id/overlay_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Indikator zoom — atas tengah, modern pill style -->
    <TextView
        android:id="@+id/zoom_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="52dp"
        android:text="1.0×"
        android:textColor="#FF00F590"
        android:textSize="17sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:gravity="center"
        android:background="@drawable/bg_zoom_pill"
        android:paddingHorizontal="18dp"
        android:paddingVertical="6dp"
        android:elevation="6dp" />

    <!-- Tombol pengaturan — kiri bawah dari HUD -->
    <TextView
        android:id="@+id/settings_btn"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="170dp"
        android:layout_marginStart="14dp"
        android:text="⚙"
        android:textSize="22sp"
        android:gravity="center"
        android:textColor="#CCFFFFFF"
        android:background="@drawable/bg_btn_dark"
        android:elevation="6dp" />

    <!-- Tombol Mod Menu — di bawah tombol pengaturan -->
    <TextView
        android:id="@+id/modmenu_btn"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="222dp"
        android:layout_marginStart="14dp"
        android:text="☰"
        android:textSize="22sp"
        android:gravity="center"
        android:textColor="#CC7C3AED"
        android:background="@drawable/bg_btn_dark"
        android:elevation="6dp" />

    <!-- Dial zoom modern — bawah -->
    <com.detector.esp.ui.ZoomDialView
        android:id="@+id/zoom_dial"
        android:layout_width="match_parent"
        android:layout_height="176dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="12dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="4dp" />

</FrameLayout>
